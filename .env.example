# Fresh People Event Ops — environment configuration
# Copy to `.env` and fill in real values. `.env` is gitignored; do NOT commit secrets.
#
# The CI secret-scan workflow fails any commit that contains a real token
# (Cloudflare `cfat_...`, Meta/WhatsApp `EAA...`, etc.). Placeholders below are
# intentionally NOT flagged.

# WhatsApp Cloud API (Meta) — used by whatsapp-api-bot.js and whatsapp-workflow*.sh
WA_ACCESS_TOKEN=PASTE_YOUR_TOKEN_HERE
WA_PHONE_NUMBER_ID=PASTE_YOUR_PHONE_NUMBER_ID
WA_VERIFY_TOKEN=fresh_people_webhook_verify_2026

# Cloudflare — used by cf_check.sh (zone status check + cache purge)
CF_API_TOKEN=PASTE_YOUR_TOKEN_HERE
CF_ZONE_ID=PASTE_YOUR_ZONE_ID

# Dashboard basic-auth (consumed by ecosystem.config.js / server-v4.js)
DASHBOARD_USER=admin
DASHBOARD_PASS=CHANGE_ME

# Optional: override the project root (defaults to the repo/worktree directory)
# PROJECT_ROOT=/home/yassin/fresh-people-event-ops
